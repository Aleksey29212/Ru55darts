# ПАРОЛЬ АДМИНИСТРАТОРА (ОБЯЗАТЕЛЬНО ИЗМЕНИТЕ В PRODUCTION)
NEXT_PUBLIC_ADMIN_PASSWORD=your_secure_password_here

# API КЛЮЧИ (Для GenAI функций, если используются)
GEMINI_API_KEY=your_api_key_here

# Firebase конфигурация (обычно подтягивается автоматически в App Hosting)
# Но может понадобиться для локальной отладки build-версии
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
