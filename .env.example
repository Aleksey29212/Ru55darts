# Пример файла настроек. Скопируйте эти ключи в раздел Environment Variables на Timeweb Cloud.
# Значения возьмите из Firebase Console -> Project Settings -> Your Apps -> Config

NEXT_PUBLIC_FIREBASE_API_KEY=ваша_строка_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ваше_приложение.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ваше_название_проекта
NEXT_PUBLIC_FIREBASE_APP_ID=ваш_номер_приложения
NEXT_PUBLIC_ADMIN_PASSWORD=1234
