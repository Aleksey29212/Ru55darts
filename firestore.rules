rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Глобальное правило доступа для прототипа DartBrig Pro.
    // Разрешает чтение и запись для всех путей, обеспечивая работу всех функций системы (импорт, профили, настройки).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}